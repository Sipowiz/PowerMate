<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PowerMateSettings.Views.SettingsPage"
             BackgroundColor="{StaticResource BgColor}"
             Title="">

    <Shell.TitleView>
        <Label Text="" />
    </Shell.TitleView>

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- ── Header ── -->
        <Grid Grid.Row="0"
              BackgroundColor="{StaticResource BgHeader}"
              Padding="20,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Knob icon -->
            <Ellipse Grid.Column="0"
                     WidthRequest="36" HeightRequest="36"
                     Stroke="{StaticResource Accent}" StrokeThickness="3"
                     VerticalOptions="Center" Margin="0,0,12,0"/>
            <Ellipse Grid.Column="0"
                     WidthRequest="13" HeightRequest="13"
                     Fill="{StaticResource Accent}"
                     VerticalOptions="Center" HorizontalOptions="Center"
                     Margin="0,0,12,0"/>

            <!-- Title -->
            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="1">
                <Label Text="Griffin PowerMate"
                       FontFamily="SegoeUISemiBold"
                       FontSize="16"
                       TextColor="{StaticResource TextPrimary}"/>
                <Label Text="Driver Settings"
                       FontSize="12"
                       TextColor="{StaticResource TextMuted}"/>
            </VerticalStackLayout>

            <!-- Connection pill -->
            <Frame Grid.Column="2"
                   x:Name="ConnPill"
                   CornerRadius="12"
                   Padding="10,4"
                   HasShadow="False"
                   BorderColor="Transparent"
                   VerticalOptions="Center">
                <Label x:Name="ConnLabel"
                       FontSize="11"
                       FontFamily="SegoeUI"/>
            </Border>
        </Grid>

        <!-- ── Scrollable body ── -->
        <ScrollView Grid.Row="1" Padding="18,0,18,8">
            <VerticalStackLayout Spacing="0">

                <!-- ROTATION -->
                <Label Text="ROTATION" Style="{StaticResource SectionTitle}"/>
                <Border Style="{StaticResource CardBorder}">
                    <VerticalStackLayout Spacing="0">

                        <!-- Volume step -->
                        <Grid Padding="16,12" ColumnDefinitions="*,Auto">
                            <Label Text="Volume step" Style="{StaticResource RowLabel}"/>
                            <Label x:Name="LblVolumeStep" Grid.Column="1"
                                   Style="{StaticResource ValueLabel}"/>
                        </Grid>
                        <Slider x:Name="SliderVolumeStep"
                                Minimum="1" Maximum="10"
                                Margin="16,0,16,12"
                                ValueChanged="OnVolumeStepChanged"/>
                        <BoxView HeightRequest="1" Color="{StaticResource Divider}" Margin="16,0"/>

                        <!-- Sensitivity -->
                        <Grid Padding="16,12" ColumnDefinitions="*,Auto">
                            <Label Text="Sensitivity" Style="{StaticResource RowLabel}"/>
                            <Label x:Name="LblSensitivity" Grid.Column="1"
                                   Style="{StaticResource ValueLabel}"/>
                        </Grid>
                        <Slider x:Name="SliderSensitivity"
                                Minimum="1" Maximum="5"
                                Margin="16,0,16,12"
                                ValueChanged="OnSensitivityChanged"/>
                        <BoxView HeightRequest="1" Color="{StaticResource Divider}" Margin="16,0"/>

                        <!-- Invert -->
                        <Grid Padding="16,14" ColumnDefinitions="*,Auto">
                            <Label Text="Invert rotation direction" Style="{StaticResource RowLabel}"/>
                            <Switch x:Name="SwitchInvert" Grid.Column="1" VerticalOptions="Center"/>
                        </Grid>

                    </VerticalStackLayout>
                </Border>

                <!-- BUTTON ACTIONS -->
                <Label Text="BUTTON ACTIONS" Style="{StaticResource SectionTitle}"/>
                <Border Style="{StaticResource CardBorder}">
                    <VerticalStackLayout Spacing="0">

                        <!-- Single click -->
                        <Grid Padding="16,12" ColumnDefinitions="*,Auto">
                            <Label Text="Single click" Style="{StaticResource RowLabel}"/>
                            <Picker x:Name="PickerClick" Grid.Column="1"
                                    WidthRequest="180"
                                    VerticalOptions="Center"/>
                        </Grid>
                        <BoxView HeightRequest="1" Color="{StaticResource Divider}" Margin="16,0"/>

                        <!-- Long press -->
                        <Grid Padding="16,12" ColumnDefinitions="*,Auto">
                            <Label Text="Long press" Style="{StaticResource RowLabel}"/>
                            <Picker x:Name="PickerLong" Grid.Column="1"
                                    WidthRequest="180"
                                    VerticalOptions="Center"/>
                        </Grid>
                        <BoxView HeightRequest="1" Color="{StaticResource Divider}" Margin="16,0"/>

                        <!-- Long press threshold -->
                        <Grid Padding="16,12" ColumnDefinitions="*,Auto">
                            <Label Text="Long press threshold" Style="{StaticResource RowLabel}"/>
                            <Label x:Name="LblLongMs" Grid.Column="1"
                                   Style="{StaticResource ValueLabel}"/>
                        </Grid>
                        <Slider x:Name="SliderLongMs"
                                Minimum="300" Maximum="2000"
                                Margin="16,0,16,12"
                                ValueChanged="OnLongMsChanged"/>

                    </VerticalStackLayout>
                </Border>

                <!-- LED -->
                <Label Text="LED" Style="{StaticResource SectionTitle}"/>
                <Border Style="{StaticResource CardBorder}">
                    <VerticalStackLayout Spacing="0">

                        <Grid Padding="16,12" ColumnDefinitions="*,Auto">
                            <Label Text="Brightness" Style="{StaticResource RowLabel}"/>
                            <Label x:Name="LblLedBrightness" Grid.Column="1"
                                   Style="{StaticResource ValueLabel}"/>
                        </Grid>
                        <Slider x:Name="SliderLedBrightness"
                                Minimum="0" Maximum="255"
                                Margin="16,0,16,12"
                                ValueChanged="OnLedBrightnessChanged"/>
                        <BoxView HeightRequest="1" Color="{StaticResource Divider}" Margin="16,0"/>

                        <Grid Padding="16,14" ColumnDefinitions="*,Auto">
                            <Label Text="Pulse on volume change" Style="{StaticResource RowLabel}"/>
                            <Switch x:Name="SwitchPulse" Grid.Column="1" VerticalOptions="Center"/>
                        </Grid>

                    </VerticalStackLayout>
                </Border>

                <!-- SYSTEM -->
                <Label Text="SYSTEM" Style="{StaticResource SectionTitle}"/>
                <Border Style="{StaticResource CardBorder}">
                    <VerticalStackLayout Spacing="0">

                        <Grid Padding="16,14" ColumnDefinitions="*,Auto">
                            <Label Text="Start with Windows" Style="{StaticResource RowLabel}"/>
                            <Switch x:Name="SwitchStartup" Grid.Column="1" VerticalOptions="Center"/>
                        </Grid>
                        <BoxView HeightRequest="1" Color="{StaticResource Divider}" Margin="16,0"/>

                        <Grid Padding="16,14" ColumnDefinitions="*,Auto">
                            <Label Text="Volume notifications" Style="{StaticResource RowLabel}"/>
                            <Switch x:Name="SwitchNotifications" Grid.Column="1" VerticalOptions="Center"/>
                        </Grid>

                    </VerticalStackLayout>
                </Border>

                <BoxView HeightRequest="16" Color="Transparent"/>

            </VerticalStackLayout>
        </ScrollView>

        <!-- ── Footer ── -->
        <Grid Grid.Row="2"
              BackgroundColor="{StaticResource BgHeader}"
              Padding="18,12"
              ColumnDefinitions="*,Auto,Auto">

            <!-- Volume status -->
            <Label x:Name="LblVolumeStatus"
                   Grid.Column="0"
                   FontSize="12"
                   TextColor="{StaticResource TextMuted}"
                   VerticalOptions="Center"/>

            <!-- Saved indicator -->
            <Label x:Name="LblSaved"
                   Grid.Column="0"
                   Text="✓  Settings saved"
                   FontSize="12"
                   TextColor="{StaticResource ConnectedFg}"
                   VerticalOptions="Center"
                   IsVisible="False"/>

            <Button Grid.Column="1"
                    Text="Cancel"
                    Style="{StaticResource CancelButton}"
                    Margin="0,0,10,0"
                    Clicked="OnCancel"/>

            <Button Grid.Column="2"
                    Text="Save"
                    Style="{StaticResource SaveButton}"
                    Clicked="OnSave"/>
        </Grid>

    </Grid>
</ContentPage>
